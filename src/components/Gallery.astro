---
const photos = [
  { src: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=600&q=80', alt: 'Habitacion de lujo', span: 'tall' },
  { src: 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=600&q=80', alt: 'Patio interior', span: '' },
  { src: 'https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=600&q=80', alt: 'Restaurante Sumaq', span: '' },
  { src: 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=600&q=80', alt: 'Spa', span: '' },
  { src: 'https://images.unsplash.com/photo-1526392060635-9d6019884377?w=600&q=80', alt: 'Vista de Cusco', span: 'wide' },
  { src: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=600&q=80', alt: 'Suite detalle', span: '' },
  { src: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=600&q=80', alt: 'Suite Imperial', span: 'tall' },
  { src: 'https://images.unsplash.com/photo-1578683010236-d716f9a3f461?w=600&q=80', alt: 'Grand Suite', span: '' },
];
---
<section class="gallery section" id="galeria">
  <div class="container">
    <p class="section-label">Galeria</p>
    <h2 class="section-title">Momentos en Casa Inti</h2>
    <div class="gold-divider"><span>&#9788;</span></div>
    <p class="section-subtitle">Descubra los espacios que hacen de Casa Inti un lugar inolvidable</p>
    <div class="gallery-grid">
      {photos.map((photo) => (
        <div class={`gallery-item ${photo.span}`}>
          <img src={photo.src} alt={photo.alt} loading="lazy" />
          <div class="gallery-overlay">
            <span>{photo.alt}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-label {
    text-align: center;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: 0.75rem;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .gallery-item.tall { grid-row: span 2; }
  .gallery-item.wide { grid-column: span 2; }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(28,25,23,0.5);
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-overlay span {
    color: #fff;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }
  }
</style>
