---
const attractions = [
  { name: 'Plaza de Armas', distance: '5 min a pie' },
  { name: 'Templo de Qoricancha', distance: '10 min a pie' },
  { name: 'Barrio de San Blas', distance: '3 min a pie' },
  { name: 'Piedra de los 12 angulos', distance: '1 min a pie' },
  { name: 'Mercado de San Pedro', distance: '12 min a pie' },
  { name: 'Sacsayhuaman', distance: '15 min en auto' },
];
---
<section class="location section" id="ubicacion">
  <div class="container">
    <div class="location-grid">
      <div class="location-content">
        <p class="location-label">Ubicacion</p>
        <h2>En el corazon de Cusco</h2>
        <div class="gold-divider" style="justify-content:flex-start;"><span>&#9788;</span></div>
        <p class="location-desc">Casa Inti se encuentra en la historica calle Hatunrumiyoc, a pasos de la famosa Piedra de los 12 Angulos y a pocos minutos de los principales atractivos de la ciudad imperial.</p>
        <div class="location-address">
          <p><strong>Direccion:</strong></p>
          <p>Calle Hatunrumiyoc 487<br />Cusco, Peru 08000</p>
        </div>
        <h4>Atracciones cercanas</h4>
        <ul class="attractions-list">
          {attractions.map((a) => (
            <li>
              <span class="attraction-name">{a.name}</span>
              <span class="attraction-distance">{a.distance}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="location-map">
        <div class="map-placeholder">
          <div class="map-inner">
            <span class="map-pin">&#9788;</span>
            <p>Casa Inti</p>
            <p class="map-coords">Calle Hatunrumiyoc 487</p>
            <p class="map-coords">Cusco, Peru</p>
            <p class="map-coords">-13.5167, -71.9783</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .location-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .location-content h2 {
    font-size: 2.5rem;
    font-weight: 300;
  }

  .location-desc {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }

  .location-address {
    margin-bottom: 2rem;
    font-size: 0.95rem;
    color: var(--text-light);
  }

  .location-address strong {
    color: var(--primary);
  }

  .location-content h4 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .attractions-list {
    list-style: none;
    padding: 0;
  }

  .attractions-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(184,134,11,0.1);
    font-size: 0.9rem;
  }

  .attraction-name { color: var(--primary); }
  .attraction-distance { color: var(--text-light); font-size: 0.85rem; }

  .map-placeholder {
    width: 100%;
    height: 450px;
    background: linear-gradient(135deg, #e7e5e4 0%, #d6d3d1 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(184,134,11,0.2);
    position: relative;
  }

  .map-placeholder::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(184,134,11,0.15);
  }

  .map-inner {
    text-align: center;
  }

  .map-pin {
    font-size: 3rem;
    color: var(--gold);
    display: block;
    margin-bottom: 1rem;
  }

  .map-inner p {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--primary);
  }

  .map-coords {
    font-family: var(--font-body) !important;
    font-size: 0.85rem !important;
    color: var(--text-light) !important;
    margin-top: 0.25rem;
  }

  @media (max-width: 900px) {
    .location-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .map-placeholder { height: 300px; }
  }
</style>
